{% extends 'core/base.html' %}
{% block content %}
<h2 class="text-2xl mb-4">Payment</h2>
<p>Ride from <b>{{ ride.pickup_location }}</b> to <b>{{ ride.dropoff_location }}</b></p>
<p>Amount: <b>${{ ride.price }}</b></p>
<!-- Stripe.js integration -->
<script src="https://js.stripe.com/v3/"></script>
<button id="pay-btn" class="bg-green-500 text-white px-4 py-2 rounded mt-4">Pay</button>
<script>
  var stripe = Stripe('{{ stripe_public_key }}');
  document.getElementById('pay-btn').onclick = function() {
    stripe.confirmCardPayment('{{ client_secret }}', {
      payment_method: {
        card: {token: 'tok_visa'} // For MVP/demo only
      }
    }).then(function(result) {
      if (result.error) {
        alert(result.error.message);
      } else {
        if (result.paymentIntent.status === 'succeeded') {
          alert('Payment successful!');
          window.location = '/booking/';
        }
      }
    });
  }
</script>
{% endblock %}